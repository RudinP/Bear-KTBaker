{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "vitest.config.ts", "electron/**/*.ts", "src/domain/**/*.ts", "src/io/**/*.ts", "src/manifest/**/*.ts", "src/electron.d.ts"]
}
